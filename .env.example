#================================================
# ENVIRONMENT CONFIGURATION - EXAMPLE FILE
#================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control
# NEVER share your API keys

#================================================
# OPENWEATHERMAP API CONFIGURATION
#================================================
# Get your FREE API key from: https://openweathermap.org/api
# 1. Go to https://openweathermap.org/api
# 2. Click "Sign Up"
# 3. Create account and verify email
# 4. Navigate to "API keys" section
# 5. Copy your API key and paste below

OPENWEATHER_API_KEY=5e6cc2841c286e83838ad7daa91e3497

#================================================
# APPLICATION SETTINGS
#================================================
# Set to 'true' for detailed logging during development
DEBUG=false

# Environment: development | staging | production
NODE_ENV=development

# Maximum retries for failed API calls
MAX_RETRIES=3

# Timeout for API requests in milliseconds
API_TIMEOUT=10000

#================================================
# NOTIFICATION SETTINGS (Optional - for future features)
#================================================
# Email notifications (when implemented)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# SMS notifications (when implemented - Twilio)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_FROM_NUMBER=+1234567890

#================================================
# DATABASE (Optional - for future features)
#================================================
# MongoDB connection string (if migrating from JSON)
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/orders

# PostgreSQL connection string (if migrating from JSON)
# DATABASE_URL=postgresql://user:password@localhost:5432/orders_db

#================================================
# LOGGING (Optional - for future features)
#================================================
# Log level: error | warn | info | debug | trace
LOG_LEVEL=info

# Log file path (if file logging is implemented)
# LOG_FILE=./logs/app.log

#================================================
# SECURITY (For production)
#================================================
# Rate limiting - requests per minute per IP
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# CORS settings (if deploying as API)
# CORS_ORIGIN=http://localhost:3000

# API rate limiting for OpenWeatherMap
# Free tier has limits, adjust based on your tier
# Free: 1000 calls/day
# Professional: 60,000 calls/day
OPENWEATHER_TIER=free

#================================================
# SCHEDULING (Optional - for future features)
#================================================
# Run checks every N minutes (e.g., 60 for every hour)
# SCHEDULE_INTERVAL_MINUTES=60

# Time zone for scheduling
# TIMEZONE=America/New_York

#================================================
# WEBHOOK (Optional - for future features)
#================================================
# Send notifications to webhook endpoint
# WEBHOOK_URL=https://your-api.com/webhook
# WEBHOOK_SECRET=your_webhook_secret_key
